# Solana Configuration
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=/home/user/.config/solana/id.json
SOLANA_NETWORK=devnet

# Backend Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database (if needed for caching/analytics)
DATABASE_URL=sqlite:./data/escrow.db

# API Keys (for notifications, monitoring, etc.)
WEBHOOK_SECRET=your_webhook_secret_here

# Frontend Configuration
REACT_APP_API_URL=http://localhost:3001
REACT_APP_SOLANA_NETWORK=devnet
REACT_APP_PROGRAM_ID=placeholder_program_id